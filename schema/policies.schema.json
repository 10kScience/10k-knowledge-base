{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.10k.science/schema/policies.schema.json",
  "title": "10k Retrieval And Response Policies",
  "type": "object",
  "required": ["name", "version", "status", "canonical_naming", "primary_urls", "call_to_action_policy", "retrieval_guidance", "accuracy_guardrails"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "status": { "const": "public" },
    "description": { "type": "string" },
    "canonical_naming": { "type": "object" },
    "primary_urls": { "type": "object" },
    "call_to_action_policy": { "type": "object" },
    "retrieval_guidance": { "type": "object" },
    "audience_guidance": {
      "type": "array",
      "items": { "type": "object" }
    },
    "accuracy_guardrails": {
      "type": "array",
      "items": { "type": "string" }
    },
    "freshness_policy": { "type": "object" }
  },
  "additionalProperties": true
}
