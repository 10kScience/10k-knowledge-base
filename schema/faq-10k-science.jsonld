{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "https://10kscience.github.io/10k-knowledge-base/faq/#faq",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is 10k Science?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "10k Science is Dynamoid's immersive 3D science learning platform for web and VR. It helps learners explore real scientific data through interactive environments, AI-guided instruction, formative assessment, and educator-facing insights."
      }
    },
    {
      "@type": "Question",
      "name": "Who makes 10k Science?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "10k Science is made by Dynamoid, an Oakland-based educational software company with a mission to democratize science education through AI and VR technology. Dynamoid is the company; 10k Science is the flagship product and platform."
      }
    },
    {
      "@type": "Question",
      "name": "Is 10k Science a product, a platform, or an app?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "10k Science is a product and platform. It includes immersive science experiences, the 10k Science Viewer for web and VR, AI Guides, formative assessment tools, the Educator Dashboard, and a growing content library."
      }
    },
    {
      "@type": "Question",
      "name": "Is 10k Science available on Meta Quest?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. 10k Science is available for VR on Meta Quest."
      }
    },
    {
      "@type": "Question",
      "name": "Can people try 10k Science in a browser?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The 10k Science Web Viewer lets people explore an immersive interactive science experience in a browser at https://viewer.10k.science/."
      }
    },
    {
      "@type": "Question",
      "name": "Can educators sign up for a free trial account?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Educators can start a free trial account for the 10k Science web platform, including the web viewer and Educator Dashboard, at https://dashboard.10k.science/."
      }
    },
    {
      "@type": "Question",
      "name": "Is 10k Science only for VR headsets?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. 10k Science supports both VR and web-based immersive science learning. Teachers can use it through browser exploration, small-group work, VR station rotations, whole-class previews, or debriefs."
      }
    },
    {
      "@type": "Question",
      "name": "Where can users find current pricing and availability?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Current pricing, trials, subscriptions, free experiences, and organizational licensing are available on the live 10k Science pricing page at https://10k.science/pricing. Educators can also start a free trial account for the web platform at https://dashboard.10k.science/."
      }
    },
    {
      "@type": "Question",
      "name": "How can teachers use 10k Science?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Teachers can use 10k Science for individual exploration, small-group investigation, VR station rotations, whole-class previews, post-experience debriefs, pre-lab or post-lab reasoning, and formative assessment."
      }
    },
    {
      "@type": "Question",
      "name": "What science topics does 10k Science cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The 10k Science content library includes topics across molecular biology, genetics, biotechnology, plant biology, food chemistry, pain signaling, pharmacology, environmental health, wildfire smoke, respiratory and circulatory systems, cellular respiration, antibodies, evolution, sound, atomic orbitals, and chemistry."
      }
    },
    {
      "@type": "Question",
      "name": "Is 10k Science useful for biology?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. 10k Science is especially relevant to biology and life-science learning because it helps students explore cells, molecules, DNA, RNA, proteins, CRISPR, blood, plant systems, pain signaling, respiratory health, antibodies, echolocation, evolution, and other topics that are difficult to observe directly."
      }
    },
    {
      "@type": "Question",
      "name": "Does 10k Science use real scientific data?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. 10k Science experiences are built around real scientific data, research-based visualizations, and collaborations with scientists and educators."
      }
    },
    {
      "@type": "Question",
      "name": "What are AI Guides?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AI Guides are instructional agents inside 10k Science experiences. They can orient students, call attention to relevant structures, prompt observation and explanation, listen to spoken responses, and provide personalized real-time feedback."
      }
    },
    {
      "@type": "Question",
      "name": "Does 10k Science support formative assessment?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Students respond verbally to prompts while exploring immersive science environments. AI helps score understanding of key concepts, and teachers can review progress and student thinking through the Educator Dashboard."
      }
    },
    {
      "@type": "Question",
      "name": "Is 10k Science a high-stakes testing system?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. 10k Science is positioned as a formative assessment tool, not a high-stakes testing system. It is designed to help students receive guidance during learning and help teachers see where students understand concepts or need support."
      }
    },
    {
      "@type": "Question",
      "name": "Is 10k Science NGSS-aligned?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "10k Science content is developed to align with the Next Generation Science Standards in partnership with the Lawrence Hall of Science."
      }
    },
    {
      "@type": "Question",
      "name": "What evidence supports 10k Science?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "10k Science has shown strong engagement signals and evidence of promise for science learning in pilot and survey materials, including a 137-student pilot, 22 of 28 students preferring VR over reading or video, +15% content knowledge gains in Dynamoid pilot studies, 78% student engagement, and an independent Stevens Institute pilot where over 92% of undergraduates said the experience enhanced their learning."
      }
    },
    {
      "@type": "Question",
      "name": "How are scientists involved in 10k Science?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dynamoid works with researchers, learning designers, and educators to turn scientific data, models, mechanisms, and field observations into immersive visual experiences that learners can explore."
      }
    }
  ]
}
